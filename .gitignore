# --- Secrets / credentials (NEVER commit these) ---
*.json.key
**/google-credentials*.json
**/gcp-key*.json
.env
.env.*

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
.venv/
venv/
env/
ENV/

# --- Streamlit ---
.streamlit/secrets.toml

# --- OS / editor cruft ---
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# --- Test / temp artifacts ---
.pytest_cache/
.coverage
htmlcov/
/tmp/
*.tmp

# --- Sample data (uploaded test prescriptions may contain real patient info -- never commit) ---
tests/sample_prescriptions/*
!tests/sample_prescriptions/.gitkeep
